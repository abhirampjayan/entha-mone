{
  "name": "entha-mone",
  "displayName": "Entha Mone",
  "description": "Plays a sound when you get errors, and celebrates when they're all gone",
  "version": "0.1.0",
  "publisher": "abhirampjayan",
  "author": "abhirampjayan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhirampjayan/entha-mone"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sound",
    "error",
    "audio",
    "notification",
    "faah"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Entha Mone",
      "properties": {
        "enthaMone.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Entha Mone sounds"
        },
        "enthaMone.volume": {
          "type": "number",
          "default": 1,
          "minimum": 0.1,
          "maximum": 1,
          "description": "Playback volume (0.1 – 1.0)"
        }
      }
    },
    "commands": [
      {
        "command": "enthaMone.toggle",
        "title": "Entha Mone: Toggle sounds on/off"
      },
      {
        "command": "enthaMone.testSound",
        "title": "Entha Mone: Test sound"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
